{
  "kind": "collectionType",
  "collectionName": "user_cars",
  "info": {
    "singularName": "user-car",
    "pluralName": "user-cars",
    "displayName": "User Car"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "production_date": {
      "type": "date"
    },
    "vin": {
      "type": "string"
    },
    "notes": {
      "type": "text"
    },
    "car_status": {
      "type": "enumeration",
      "enum": [
        "Owned",
        "Sold"
      ]
    },
    "visibility": {
      "type": "enumeration",
      "enum": [
        "Public",
        "For registered",
        "Private"
      ]
    },
    "users_permissions_user": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "user_cars"
    },
    "modification": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::modification.modification",
      "inversedBy": "user_cars"
    },
    "engine": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::engine.engine",
      "inversedBy": "user_cars"
    },
    "transmission": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::transmission.transmission",
      "inversedBy": "user_cars"
    },
    "market": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::market.market",
      "inversedBy": "user_cars"
    },
    "service_logs": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::service-log.service-log",
      "mappedBy": "user_car"
    },
    "generation": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::generation.generation",
      "inversedBy": "user_cars"
    }
  }
}
