{
  "kind": "collectionType",
  "collectionName": "modifications",
  "info": {
    "singularName": "modification",
    "pluralName": "modifications",
    "displayName": "Modification"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": false
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "lci": {
      "type": "enumeration",
      "enum": [
        "Pre-LCI",
        "LCI"
      ]
    },
    "fuel_type": {
      "type": "enumeration",
      "enum": [
        "Petrol",
        "Diesel",
        "Hydrogen",
        "Electricity"
      ]
    },
    "displacement": {
      "type": "integer"
    },
    "power_hp": {
      "type": "integer"
    },
    "torque_nm": {
      "type": "integer"
    },
    "acceleration_0_100": {
      "type": "decimal"
    },
    "max_speed": {
      "type": "integer"
    },
    "engines": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::engine.engine",
      "inversedBy": "modifications"
    },
    "transmissions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::transmission.transmission",
      "inversedBy": "modifications"
    },
    "steerings": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::steering.steering",
      "inversedBy": "modifications"
    },
    "markets": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::market.market",
      "inversedBy": "modifications"
    },
    "standard_equipments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::standard-equipment.standard-equipment",
      "mappedBy": "modification"
    },
    "user_cars": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-car.user-car",
      "mappedBy": "modification"
    },
    "generation": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::generation.generation",
      "inversedBy": "modifications"
    },
    "model_codes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::model-code.model-code",
      "mappedBy": "modification"
    }
  }
}
