{
  "kind": "collectionType",
  "collectionName": "articles",
  "info": {
    "singularName": "article",
    "pluralName": "articles",
    "displayName": "Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "intro": {
      "type": "text",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "content": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "difficulty": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "enum": [
        "Easy",
        "Medium",
        "Hard"
      ]
    },
    "published_date": {
      "type": "date",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "article_status": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "enum": [
        "Draft",
        "Published",
        "Pending",
        "Unpublished"
      ]
    },
    "category": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::article-category.article-category",
      "inversedBy": "articles"
    },
    "engines": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::engine.engine",
      "inversedBy": "articles"
    },
    "options": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::option.option",
      "inversedBy": "articles"
    },
    "tags": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article-tag.article-tag",
      "inversedBy": "articles"
    },
    "special_versions": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::special-version.special-version",
      "inversedBy": "articles"
    },
    "attachment": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "article.attachment",
      "repeatable": true
    },
    "Source": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "article.source",
      "repeatable": true
    },
    "Video": {
      "type": "component",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "component": "article.video",
      "repeatable": true
    },
    "generations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::generation.generation",
      "inversedBy": "articles"
    }
  }
}
