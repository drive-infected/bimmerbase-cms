    "steering": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::steering.steering",
      "inversedBy": "model_codes"
    },
    "market": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::market.market",
