{
  "kind": "collectionType",
  "collectionName": "engines",
  "info": {
    "singularName": "engine",
    "pluralName": "engines",
    "displayName": "Engine"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "index": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "engine_family": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::engine-family.engine-family",
      "inversedBy": "engines"
    },
    "slug": {
      "type": "uid",
      "targetField": "index"
    },
    "fuel_type": {
      "type": "enumeration",
      "enum": [
        "Petrol",
        "Diesel"
      ]
    },
    "displacement": {
      "type": "integer"
    },
    "bore_stroke": {
      "type": "string"
    },
    "compression_ratio": {
      "type": "decimal"
    },
    "power_hp": {
      "type": "integer"
    },
    "torque_nm": {
      "type": "integer"
    },
    "max_rpm": {
      "type": "integer"
    },
    "ecu": {
      "type": "string"
    },
    "injection": {
      "type": "enumeration",
      "enum": [
        "Single-point",
        "Multi-point",
        "Direct",
        "Indirect",
        "Common Rail"
      ]
    },
    "aspiration": {
      "type": "enumeration",
      "enum": [
        "Naturally aspirated",
        "Turbocharged",
        "Compressor"
      ]
    },
    "valves_per_cylinder": {
      "type": "integer"
    },
    "timing_drive": {
      "type": "enumeration",
      "enum": [
        "Chain",
        "Belt"
      ]
    },
    "vvt": {
      "type": "enumeration",
      "enum": [
        "None",
        "Single VANOS",
        "Double VANOS",
        "Valvetronic"
      ]
    },
    "oil_type": {
      "type": "string"
    },
    "oil_capacity": {
      "type": "decimal"
    },
    "coolant_type": {
      "type": "string"
    },
    "coolant_capacity": {
      "type": "decimal"
    },
    "modifications": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::modification.modification",
      "mappedBy": "engines"
    },
    "articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article",
      "mappedBy": "engines"
    },
    "special_versions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::special-version.special-version",
      "mappedBy": "engine"
    },
    "engine_versions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::engine-version.engine-version",
      "mappedBy": "engine"
    },
    "user_cars": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::user-car.user-car",
      "mappedBy": "engine"
    },
    "generations": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::generation.generation",
      "inversedBy": "engines"
    },
    "model_codes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::model-code.model-code",
      "mappedBy": "engine"
    }
  }
}
