{
  "kind": "collectionType",
  "collectionName": "engine_families",
  "info": {
    "singularName": "engine-family",
    "pluralName": "engine-families",
    "displayName": "Engine Family"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "code": {
      "type": "string",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      },
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "code"
    },
    "engine_type": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Inline",
        "V"
      ]
    },
    "cylinders": {
      "type": "integer",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "layout": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Longitudinal",
        "Transverse"
      ]
    },
    "fuel_type": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Petrol",
        "Diesel"
      ]
    },
    "head_material": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Cast iron",
        "Aluminium"
      ]
    },
    "block_material": {
      "type": "enumeration",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      },
      "enum": [
        "Cast iron",
        "Aluminium"
      ]
    },
    "production_start": {
      "type": "date",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "production_end": {
      "type": "date",
      "pluginOptions": {
        "i18n": {
          "localized": false
        }
      }
    },
    "successor": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::engine-family.engine-family",
      "inversedBy": "predecessor"
    },
    "predecessor": {
      "type": "relation",
      "relation": "oneToOne",
      "target": "api::engine-family.engine-family",
      "mappedBy": "successor"
    },
    "engines": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::engine.engine",
      "mappedBy": "engine_family"
    },
    "features": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "blocks",
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "model_codes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::model-code.model-code",
      "mappedBy": "engine_family"
    },
    "articles": {
      "type": "relation",
      "relation": "manyToMany",
      "target": "api::article.article",
      "mappedBy": "engine_families"
    }
  }
}
