{
  "kind": "collectionType",
  "collectionName": "series",
  "info": {
    "singularName": "serie",
    "pluralName": "series",
    "displayName": "Series"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "unique": true
    },
    "slug": {
      "type": "uid",
      "targetField": "title"
    },
    "generations": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::generation.generation",
      "mappedBy": "series"
    },
    "special_versions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::special-version.special-version",
      "mappedBy": "series"
    }
  }
}
